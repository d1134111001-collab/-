<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <title>抽名字工具</title>
    <style>
        body {
            text-align: center;
            font-family: Arial;
            margin-top: 100px;
        }
        button {
            font-size: 20px;
            padding: 10px 20px;
        }
        #result {
            margin-top: 30px;
            font-size: 30px;
            color: blue;
        }
    </style>
</head>
<body>

    <h1>🎯 隨機抽名字</h1>
    <button onclick="drawName()">抽一個人</button>

    <div id="result"></div>

    <script>
        const names = ["蔣宥辰", "毛霆漢", "李俊緯", "王廷瑋"];

        function drawName() {
            const randomIndex = Math.floor(Math.random() * names.length);
            document.getElementById("result").innerText = names[randomIndex];
        }
    </script>

</body>
</html>
